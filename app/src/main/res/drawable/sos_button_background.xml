<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/sos_ripple">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#FF5252"
                android:endColor="@color/sos_red"
                android:angle="270" />
            <size android:width="160dp" android:height="160dp" />
            <stroke android:width="4dp" android:color="#40FFFFFF" />
        </shape>
    </item>
</ripple>